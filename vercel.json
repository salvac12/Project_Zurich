{
  "version": 2,
  "name": "project-zurich",
  "functions": {
    "api/**/*.js": { "runtime": "nodejs20.x" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },

    { "src": "/", "dest": "/index.html", "headers": { "Cache-Control": "no-store" } },
    { "src": "/project-zurich-equity.html", "status": 308, "headers": { "Location": "/senior_financing_es.html" } },
    { "src": "/(.*)\\.html", "headers": { "Cache-Control": "no-store" }, "continue": true },
    { "src": "/(.+)", "dest": "/$1" }
  ]
}
